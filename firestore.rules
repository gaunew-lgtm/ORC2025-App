rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidLeaderboard(data) {
      return data.keys().hasAll(['team', 'score', 'jobs', 'createdAt', 'stats'])
        && data.keys().size() == 5
        && data.team is string
        && data.team.size() <= 200
        && data.score is int
        && data.jobs is list
        && data.jobs.size() <= 20
        && data.stats is map
        && data.createdAt is timestamp;
    }

    match /leaderboard/{entryId} {
      allow read, get, list: if true;
      allow create: if isValidId(entryId)
                    && isValidLeaderboard(incoming())
                    && incoming().createdAt == request.time;
      allow delete: if true;
      allow update: if isValidId(entryId)
                    && isValidLeaderboard(incoming())
                    && incoming().createdAt == resource.data.createdAt;
    }
  }
}
